{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Windows Release (PyInstaller)",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "PyInstaller",
        "--clean",
        "--noconfirm",
        "--onefile",
        "--name",
        "cursepante-windows",
        "--hidden-import=PIL._tkinter_finder",
        "--add-binary",
        "C:/Users/Tail/.pyenv/pyenv-win/versions/3.12.10/DLLs/tcl86t.dll;.",
        "--add-binary",
        "C:/Users/Tail/.pyenv/pyenv-win/versions/3.12.10/DLLs/tk86t.dll;.",
        "--add-data",
        "C:/Users/Tail/.pyenv/pyenv-win/versions/3.12.10/tcl;tcl",
        "--distpath",
        "dist",
        "--workpath",
        "build/pywin",
        "cursepante.py"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build AppImage (WSL)",
      "type": "shell",
      "command": "wsl",
      "args": [
        "bash",
        "-lc",
        "cd \"$(wslpath '${workspaceFolder}')\" && bash scripts/build_appimage.sh"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build Flatpak (WSL)",
      "type": "shell",
      "command": "wsl",
      "args": [
        "bash",
        "-lc",
        "cd \"$(wslpath '${workspaceFolder}')\" && bash scripts/build_flatpak.sh"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Tag and Push Release Version",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "$version = '${input:releaseVersion}'; if ([string]::IsNullOrWhiteSpace($version)) { throw 'Release version cannot be empty.' }; $tag = if ($version.StartsWith('v')) { $version } else { \"v$version\" }; git show-ref --tags --verify --quiet \"refs/tags/$tag\"; if ($LASTEXITCODE -eq 0) { throw \"Tag $tag already exists locally. Use a new version or delete the existing tag.\" }; git tag -a $tag -m \"Release $tag\"; git push git@github.com:chleved/curseforge-browser.git main; git push git@github.com:chleved/curseforge-browser.git $tag"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build All Executables",
      "dependsOn": [
        "Build Windows Release (PyInstaller)",
        "Build AppImage (WSL)",
        "Build Flatpak (WSL)"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "releaseVersion",
      "type": "promptString",
      "description": "Release version (for example: 1.0.1 or v1.0.1)",
      "default": "1.0.1"
    }
  ]
}